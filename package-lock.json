.weaveStrip {
  padding: 72px 60px;
  background: linear-gradient(135deg, rgba(42,107,194,0.06) 0%, rgba(123,63,160,0.06) 100%);
  border-top: 1px solid rgba(42,107,194,0.08);
  border-bottom: 1px solid rgba(42,107,194,0.08);
  text-align: center;
  position: relative;
  z-index: 1;
}
.weaveStrip h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(26px, 3.5vw, 44px);
  font-weight: 400;
  line-height: 1.3;
  max-width: 740px;
  margin: 0 auto 24px;
  color: var(--text);
}
.weaveStrip h2 em {
  color: var(--blue);
  font-style: italic;
}
.weaveStrip p {
  font-size: 16px;
  color: var(--muted);
  font-weight: 300;
  max-width: 560px;
  margin: 0 auto 40px;
  line-height: 1.8;
}

.paths {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  margin-bottom: 44px;
}
.path {
  padding: 11px 22px;
  background: rgba(255,255,255,0.7);
  border: 1px solid rgba(255,255,255,0.95);
  border-radius: 4px;
  font-size: 12px;
  letter-spacing: 1px;
  color: var(--text);
  font-weight: 500;
  backdrop-filter: blur(8px);
  transition: all 0.2s;
}
.path:hover {
  background: rgba(255,255,255,0.95);
  box-shadow: 0 6px 20px rgba(0,0,0,0.07);
  transform: translateY(-2px);
}
.path span {
  color: var(--blue);
  margin-right: 6px;
}

@media (max-width: 768px) {
  .weaveStrip { padding: 56px 20px; }
  .weaveStrip h2 { font-size: clamp(22px, 6vw, 32px); }
  .paths { gap: 8px; }
  .path { font-size: 11px; padding: 9px 16px; }
}
