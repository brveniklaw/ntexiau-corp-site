.tickerWrap {
  width: 100%;
  overflow: hidden;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
  background: rgba(255,255,255,0.45);
  backdrop-filter: blur(8px);
  padding: 12px 0;
  z-index: 1;
  position: relative;
}

.ticker {
  display: flex;
  white-space: nowrap;
  width: max-content;
  animation: ticker 30s linear infinite;
}

.item {
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(42,107,194,0.4);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 60px;
  margin-right: 60px;
}

.dot {
  color: rgba(123,63,160,0.3);
}

@keyframes ticker {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

@media (max-width: 768px) {
  .item { font-size: 9px; letter-spacing: 2px; }
}
